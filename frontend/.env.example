# Supabase (OBRIGATÓRIO)
NEXT_PUBLIC_SUPABASE_URL=sua-url-supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Supabase Service Role — APENAS em API Routes Next.js (nunca no cliente)
# Obter em: Supabase → Settings → API → service_role
# ⚠️ NUNCA commitar a chave real — apenas este template
# ⚠️ Marcar como "Sensitive" no painel Vercel
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
